#!/bin/sh
prev=""
for arg in "$@"; do
  # Block --no-verify and -n flag
  if [ "$arg" = "--no-verify" ] || [ "$arg" = "-n" ]; then
    echo ""
    echo "❌ ERROR: --no-verify is disabled in this project."
    echo "   All pre-commit and commit-msg checks are mandatory."
    echo "   Fix your code or commit message to proceed."
    echo ""
    exit 1
  fi
  # Block git -c core.hooksPath=/dev/null (nullifies all hooks)
  if [ "$prev" = "-c" ]; then
    case "$arg" in
      core.hooksPath=*)
        echo ""
        echo "❌ ERROR: Overriding core.hooksPath is disabled in this project."
        echo "   All pre-commit and commit-msg checks are mandatory."
        echo ""
        exit 1
        ;;
    esac
  fi
  prev="$arg"
done
exec /usr/bin/git "$@"
